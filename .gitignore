# ============================================================
#  DynamicPxE - WinPE Deployment Tool
#  .gitignore
# ============================================================

# ── Build outputs ─────────────────────────────────────────────
boot.wim
*.wim
Build/

# ── WinPE drivers (large, extracted from vendor CAB)
WinPEDrivers/

# ── Site-specific config (contains sensitive environment info)
# Copy DeployConfig.example.json -> DeployConfig.json  and fill in your settings
# Copy DriverMap.example.json    -> DriverMap.json     and add any overrides needed
Config/DeployConfig.json
Config/DriverMap.json

# ── Branding assets (org-specific, not for public repo)
Resources/*.png
Resources/*.ico
Resources/*.jpg
Resources/*.bmp

# Keep the README in Resources
!Resources/README.txt

# ── Windows junk ──────────────────────────────────────────────
Thumbs.db
desktop.ini
*.tmp

# ── PowerShell ────────────────────────────────────────────────
*.ps1xml

# ── Editor files ──────────────────────────────────────────────
.vscode/
*.code-workspace
